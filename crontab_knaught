# Run every 15 minutes
*/15 * * * * /home/knaught/scripts/newsboat-refresh.sh

# Run Twitch VOD downloader at 6pm, 8pm, and 10pm every day
# Hopefully this cadence will allow me to have VODs downloaded
# at somewhat of a convenient time
# 0 18,20,22 * * * DISPLAY=:0 DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus /home/knaught/scripts/twitch-vod-downloader.sh >> /tmp/twitch-vod-download.log 2>&1

# Run script to download all YouTube videos from
# starred list in newsboat
0 */6 * * * /home/knaught/scripts/auto-download-starred.sh

# Update the list of live Twitch streamers every 5 minutes
*/5 * * * * /home/knaught/scripts/update-live-list.sh

# Update all my pacman and yay packages every hour
0 * * * * ~/home/knaught/scripts/backup-packages.sh

# Cleanup YouTube thumbnails if not accessed in 30 days
0 3 * * 0 find ~/.cache/yt-thumbnails -type f -atime +30 -delete

# Update yay and pacman packages and push them to dotfiles repo once a day
00 15 * * * /home/knaught/scripts/update-packages.sh
