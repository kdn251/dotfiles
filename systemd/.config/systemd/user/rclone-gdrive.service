[Unit]
Description=RClone Google Drive Mount for Cryptomator
After=network-online.target

[Service]
Type=simple
ExecStart=/usr/bin/rclone mount gdrive: %h/GDrive \
    --vfs-cache-mode full \
    --vfs-disk-space-total-size 5T \
    --rc \
    --rc-no-auth \
    --rc-addr localhost:5572
ExecStop=/usr/bin/fusermount -u %h/GDrive
Restart=on-failure

[Install]
WantedBy=default.target
