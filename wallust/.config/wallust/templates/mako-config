# Global settings
max-history=50
sort=-time

# Appearance
font=monospace 10
width=300
height=100
margin=10
padding=10
border-size=1
border-radius=5

# Colors (themed by wallust)
background-color={{background}}ee
text-color={{foreground}}ff
border-color={{color4}}ff
progress-color=over {{color8}}

# Behavior
default-timeout=5000
ignore-timeout=0

[urgency=high]
border-color={{color3}}ff
default-timeout=0
